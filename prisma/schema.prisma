// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    seed     = "prisma/seed.ts"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}

enum EtablissementType {
    HOPITAL
    CLINIQUE
}

model Etablissement {
    id              String            @id @default(cuid())
    status          Boolean
    group           String?
    central         String?
    name            String
    type            EtablissementType
    isClient        Boolean
    departement     Departement?      @relation(fields: [departementId], references: [id])
    departementId   String?
    adresseComp     String?
    adresse         String
    codePostal      String
    ville           String
    telephone       String
    Chirurgien      Chirurgien[]
    EtablissementAO EtablissementAO[]
}

enum Surgery {
    HIC
    HIL
    HOC
    HOL
    EIPL
    EIPC
    ERM
    PROLAPSUS
    BSU
}

enum Fabricant {
    SWING
    AUTRES
}

model Product {
    id                String              @id @default(cuid())
    reference         String              @unique
    fabricant         Fabricant
    surgery           Surgery[]
    models            Model[]
    ReferenceChir     ReferenceChir[]
    ProductLot        ProductLot[]
    ProductAvancement ProductAvancement[]
}

enum Civilite {
    M
    MME
    AUTRES
}

enum Jour {
    LUNDI
    MARDI
    MERCREDI
    JEUDI
    VENDREDI
}

enum Service {
    CHIR_DIGESTIF
    CHIR_UROLOGIE
    CHIR_GINECO
    PHARMACIE
    X_BLOC
}

enum Fonction {
    CHIR
    IBODE
    PROFESSEUR
    PRACTICIEN
    CHEF_DE_SERVICE
    PHARM_GERANT
    PHARM_ADJOINT
}

model Chirurgien {
    id                   String                 @id @default(cuid())
    civilite             Civilite
    fonction             Fonction
    firstname            String
    lastname             String
    email                String                 @unique
    phone                String
    phone2               String?
    adresse              String?
    service              Service
    joursBloc            Jour[]
    joursConsult         Jour[]
    etablissementId      String
    etablissement        Etablissement          @relation(fields: [etablissementId], references: [id])
    references           ReferenceChir[]
    isDiffusion          Boolean                @default(false)
    usingSurgery         UsingSurgery[]
    ChirurgienRendezVous ChirurgienRendezVous[]
}

model ReferenceChir {
    id           String     @id @default(cuid())
    chirurgien   Chirurgien @relation(fields: [chirurgienId], references: [id], onDelete: Cascade)
    chirurgienId String
    product      Product    @relation(fields: [productId], references: [id])
    productId    String
    surgery      Surgery
}

model ProductAvancement {
    id           String     @id @default(cuid())
    product      Product    @relation(fields: [productId], references: [id])
    productId    String
    avancementId String
    avancement   Avancement @relation(fields: [avancementId], references: [id])
}

model Avancement {
    id           String              @id @default(cuid())
    avancement   Int
    products     ProductAvancement[]
    UsingSurgery UsingSurgery[]
}

model UsingSurgery {
    id           String      @id @default(cuid())
    surgery      Surgery
    chirurgien   Chirurgien  @relation(fields: [chirurgienId], references: [id], onDelete: Cascade)
    avancement   Avancement? @relation(fields: [avancementId], references: [id])
    avancementId String?
    chirurgienId String
    isUsing      Boolean     @default(true)
    isTapp       Boolean     @default(false)
    isTep        Boolean     @default(false)
}

model Model {
    id                   String                 @id @default(cuid())
    name                 String                 @unique
    product              Product                @relation(fields: [productId], references: [id])
    productId            String
    ProductLot           ProductLot[]
    ModelEssaiRendezVous ModelEssaiRendezVous[]
}

model Departement {
    id            String          @id @default(cuid())
    name          String
    code          String
    secteur       Secteur?        @relation(fields: [secteurId], references: [id])
    secteurId     String?
    Etablissement Etablissement[]
}

model Secteur {
    id          String        @id @default(cuid())
    name        String
    secteurUser SecteurUser[]
    departement Departement[]
}

model SecteurUser {
    id        String  @id @default(cuid())
    secteurId String
    userId    String
    secteur   Secteur @relation(fields: [secteurId], references: [id], onDelete: Cascade)
    user      User    @relation(fields: [userId], references: [id])
}

enum SourceAO {
    GHT
    GROUPE
    CH
    OFFRE
}

model EtablissementAO {
    id              String        @id @default(cuid())
    sourceId        String
    source          Source        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
    etablissement   Etablissement @relation(fields: [etablissementId], references: [id])
    etablissementId String
}

enum TypeMarche {
    CHIR_DIGESTIF
    CHIR_UROLOGIE
    CHIR_GINECO
}

enum Attribution {
    INFRUCTUEUX
    SANS_SUITE
    EN_COURS
}

model Marche {
    id       String     @id @default(cuid())
    type     TypeMarche
    sourceId String
    source   Source     @relation(fields: [sourceId], references: [id])
    lot      Lot[]
}

model ProductLot {
    id        String   @id @default(cuid())
    productId String?
    product   Product? @relation(fields: [productId], references: [id])
    modelId   String?
    model     Model?   @relation(fields: [modelId], references: [id])
    lot       Lot      @relation(fields: [lotId], references: [id], onDelete: Cascade)
    lotId     String
    prix      Float?
}

model Lot {
    id          String       @id @default(cuid())
    name        String
    numero      String
    marche      Marche       @relation(fields: [marcheId], references: [id])
    marcheId    String
    fabricant   Fabricant?
    attribution Attribution
    productLot  ProductLot[]
}

model Source {
    id String @id @default(cuid())

    status          Boolean           @default(false)
    source          SourceAO
    name            String
    etablissementAO EtablissementAO[]

    dateDebut    DateTime
    dateFin      DateTime
    consultation String
    numero       String
    objet        String
    marche       Marche[]

    createdBy   User?    @relation(fields: [createdById], references: [id])
    createdById String?
    createdAt   DateTime @default(now())
}

// Necessary for Next auth
model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? // @db.Text
    access_token      String? // @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? // @db.Text
    session_state     String?
    user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum RoleName {
    ADMIN
    CHEF
    COMMERCIAL
}

model Role {
    id   String   @id @default(cuid())
    name RoleName
    user User[]
}

model ChirurgienRendezVous {
    id           String     @id @default(cuid())
    chirurgien   Chirurgien @relation(fields: [chirurgienId], references: [id])
    chirurgienId String
    rendezVous   RendezVous @relation(fields: [rendezVousId], references: [id])
    rendezVousId String
    done         Boolean    @default(false)
    observation  String?
}

enum RendezVousType {
    RDV1
    RDV1_CONSULT_CHIR
    RDV1_BLOC_CHIR
    RDV1_SBO
    RDV1_IMPLANTATION
    RDV2
    RDV2_CONSULT_CHIR
    RDV2_BLOC_CHIR
    RDV2_SBO
    RDV2_IMPLANTATION
    RDV_STAFF_CHIR
    RDV_VALIDATION
    RDV_FORMATION
    ESSAI
}

enum Pose {
    MONO
    BILLATERAL
}

model ModelEssaiRendezVous {
    id           String     @id @default(cuid())
    model        Model      @relation(fields: [modelId], references: [id])
    modelId      String
    rendezVous   RendezVous @relation(fields: [rendezVousId], references: [id])
    rendezVousId String
    surgery      Surgery
    done         Boolean    @default(false)
    validation   Boolean    @default(false)
    observation  String?
    pose         Pose?
    schedule     Boolean    @default(false)
    filePath     String?
}

model RendezVous {
    id                   String                 @id @default(cuid())
    date                 DateTime
    dateFin              DateTime
    chirurgiens          ChirurgienRendezVous[]
    type                 RendezVousType
    commercial           User                   @relation(fields: [commercialId], references: [id])
    commercialId         String
    googleEventId        String? // Ajouter ce champ pour stocker l'ID de l'événement Google
    ModelEssaiRendezVous ModelEssaiRendezVous[]
    nextRendezVous       RendezVous[]           @relation("NextRendezVous")
    prevRendezVous       RendezVous?            @relation("NextRendezVous", fields: [prevRendezVousId], references: [id])
    prevRendezVousId     String?
}

model User {
    id               String    @id @default(cuid())
    firstname        String?
    lastname         String?
    username         String?   @unique
    password         String?
    email            String?   @unique
    phone            String?
    image            String?
    roleId           String
    accounts         Account[]
    sessions         Session[]
    role             Role      @relation(fields: [roleId], references: [id])
    googleCalendarId String? // Ajouter ce champ pour stocker l'ID du calendrier dédié

    SecteurUser SecteurUser[]
    Source      Source[]
    RendezVous  RendezVous[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}
